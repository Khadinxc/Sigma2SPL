# Title: Google Workspace Granted Domain API Access
# Author: Austin Songer
# Date: 2021-08-23
# Level: medium
# Description: Detects when an API access service account is granted domain authority.
# MITRE Tactic: Privilege Escalation
# Tags: attack.privilege-escalation, attack.persistence, attack.t1098
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/cloud/gcp/gworkspace/gcp_gworkspace_granted_domain_api_access.yml

eventName="AUTHORIZE_API_CLIENT_ACCESS" eventService="admin.googleapis.com"