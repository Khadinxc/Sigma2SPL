# Title: Shell Execution Of Process Located In Tmp Directory
# Author: Joseliyo Sanchez, @Joseliyo_Jstnk
# Date: 2023-06-02
# Level: high
# Description: Detects execution of shells from a parent process located in a temporary (/tmp) directory
# MITRE Tactic: Execution
# Tags: attack.execution
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/linux/process_creation/proc_creation_lnx_susp_shell_child_process_from_parent_tmp_folder.yml

Image IN ("*/bash", "*/csh", "*/dash", "*/fish", "*/ksh", "*/sh", "*/zsh") ParentImage="/tmp/*"