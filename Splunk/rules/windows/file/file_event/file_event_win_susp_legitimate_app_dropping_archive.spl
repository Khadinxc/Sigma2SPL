# Title: Legitimate Application Dropped Archive
# Author: frack113, Florian Roth
# Date: 2022-08-21
# Level: high
# Description: Detects programs on a Windows system that should not write an archive to disk
# MITRE Tactic: Uncategorized
# Tags: attack.stealth, attack.t1218
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/file/file_event/file_event_win_susp_legitimate_app_dropping_archive.yml

Image IN ("*\\winword.exe", "*\\excel.exe", "*\\powerpnt.exe", "*\\msaccess.exe", "*\\mspub.exe", "*\\eqnedt32.exe", "*\\visio.exe", "*\\wordpad.exe", "*\\wordview.exe", "*\\certutil.exe", "*\\certoc.exe", "*\\CertReq.exe", "*\\Desktopimgdownldr.exe", "*\\esentutl.exe", "*\\finger.exe", "*\\notepad.exe", "*\\AcroRd32.exe", "*\\RdrCEF.exe", "*\\mshta.exe", "*\\hh.exe") TargetFilename IN ("*.zip", "*.rar", "*.7z", "*.diagcab", "*.appx")