# Title: Office Macro File Creation From Suspicious Process
# Author: frack113, Nasreddine Bencherchali (Nextron Systems)
# Date: 2022-01-23
# Level: high
# Description: Detects the creation of a office macro file from a a suspicious process
# MITRE Tactic: Initial Access
# Tags: attack.initial-access, attack.t1566.001
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/file/file_event/file_event_win_office_macro_files_from_susp_process.yml

Image IN ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR ParentImage IN ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") TargetFilename IN ("*.docm", "*.dotm", "*.xlsm", "*.xltm", "*.potm", "*.pptm")