# Title: Invoke-Obfuscation Via Use Rundll32 - PowerShell
# Author: Nikita Nazarov, oscd.community
# Date: 2019-10-08
# Level: high
# Description: Detects Obfuscated Powershell via use Rundll32 in Scripts
# MITRE Tactic: Execution
# Tags: attack.stealth, attack.t1027, attack.execution, attack.t1059.001
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/powershell/powershell_script/posh_ps_invoke_obfuscation_via_use_rundll32.yml

ScriptBlockText IN ("*value*", "*invoke*", "*comspec*", "*iex*") ScriptBlockText="*&&*" ScriptBlockText="*rundll32*" ScriptBlockText="*shell32.dll*" ScriptBlockText="*shellexec_rundll*"