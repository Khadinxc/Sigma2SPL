# Title: Lolbin Unregmp2.exe Use As Proxy
# Author: frack113
# Date: 2022-12-29
# Level: medium
# Description: Detect usage of the "unregmp2.exe" binary as a proxy to launch a custom version of "wmpnscfg.exe"
# MITRE Tactic: Uncategorized
# Tags: attack.stealth, attack.t1218
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_lolbin_unregmp2.yml

CommandLine="* -HideWMP*" OR CommandLine="* /HideWMP*" OR CommandLine="* –HideWMP*" OR CommandLine="* —HideWMP*" OR CommandLine="* ―HideWMP*" Image="*\\unregmp2.exe" OR OriginalFileName="unregmp2.exe"