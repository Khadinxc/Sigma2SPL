# Title: Suspicious Child Process of AspNetCompiler
# Author: Nasreddine Bencherchali (Nextron Systems)
# Date: 2023-08-14
# Level: high
# Description: Detects potentially suspicious child processes of "aspnet_compiler.exe".
# MITRE Tactic: Execution
# Tags: attack.execution, attack.stealth, attack.t1127
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_aspnet_compiler_susp_child_process.yml

Image IN ("*\\calc.exe", "*\\notepad.exe") OR Image IN ("*\\Users\\Public\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Local\\Roaming\\*", "*:\\Temp\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*") ParentImage="*\\aspnet_compiler.exe"