# Title: Uncommon AddinUtil.EXE CommandLine Execution
# Author: Michael McKinley (@McKinleyMike), Tony Latteri (@TheLatteri)
# Date: 2023-09-18
# Level: medium
# Description: Detects execution of the Add-In deployment cache updating utility (AddInutil.exe) with uncommon Addinroot or Pipelineroot paths. An adversary may execute AddinUtil.exe with uncommon Addinroot/Pipelineroot paths that point to the adversaries Addins.Store payload.
# MITRE Tactic: Uncategorized
# Tags: attack.stealth, attack.t1218
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_addinutil_uncommon_cmdline.yml

CommandLine IN ("*-AddInRoot:*", "*-PipelineRoot:*") Image="*\\addinutil.exe" OR OriginalFileName="AddInUtil.exe" NOT (CommandLine IN ("*-AddInRoot:\"C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-AddInRoot:C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-PipelineRoot:\"C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-PipelineRoot:C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*"))