# Title: Suspicious Provlaunch.EXE Child Process
# Author: Nasreddine Bencherchali (Nextron Systems)
# Date: 2023-08-08
# Level: high
# Description: Detects suspicious child processes of "provlaunch.exe" which might indicate potential abuse to proxy execution.
# MITRE Tactic: Uncategorized
# Tags: attack.stealth, attack.t1218
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_provlaunch_susp_child_process.yml

Image IN ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR Image IN ("*:\\PerfLogs\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*\\AppData\\Temp\\*", "*\\Windows\\System32\\Tasks\\*", "*\\Windows\\Tasks\\*", "*\\Windows\\Temp\\*") ParentImage="*\\provlaunch.exe"