# Title: Suspicious DLL Loaded via CertOC.EXE
# Author: Nasreddine Bencherchali (Nextron Systems)
# Date: 2023-02-15
# Level: high
# Description: Detects when a user installs certificates by using CertOC.exe to load the target DLL file.
# MITRE Tactic: Uncategorized
# Tags: attack.stealth, attack.t1218
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_certoc_load_dll_susp_locations.yml

CommandLine="* -LoadDLL *" OR CommandLine="* /LoadDLL *" OR CommandLine="* –LoadDLL *" OR CommandLine="* —LoadDLL *" OR CommandLine="* ―LoadDLL *" Image="*\\certoc.exe" OR OriginalFileName="CertOC.exe" CommandLine IN ("*\\Appdata\\Local\\Temp\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Users\\Public\\*", "*C:\\Windows\\Tasks\\*", "*C:\\Windows\\Temp\\*")