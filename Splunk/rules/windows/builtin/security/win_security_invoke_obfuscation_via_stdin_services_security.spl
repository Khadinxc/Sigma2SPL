# Title: Invoke-Obfuscation Via Stdin - Security
# Author: Nikita Nazarov, oscd.community
# Date: 2020-10-12
# Level: high
# Description: Detects Obfuscated Powershell via Stdin in Scripts
# MITRE Tactic: Execution
# Tags: attack.stealth, attack.t1027, attack.execution, attack.t1059.001
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/builtin/security/win_security_invoke_obfuscation_via_stdin_services_security.yml

EventID=4697 ServiceFileName IN ("*environment*", "*invoke*", "*${input)*") ServiceFileName="*set*" ServiceFileName="*&&*"