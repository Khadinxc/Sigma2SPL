# Title: Weak Encryption Enabled and Kerberoast
# Author: @neu5ron
# Date: 2017-07-30
# Level: high
# Description: Detects scenario where weak encryption is enabled for a user profile which could be used for hash/password cracking.
# MITRE Tactic: Uncategorized
# Tags: attack.defense-impairment, attack.t1685
# Reference: https://github.com/SigmaHQ/sigma/blob/master/rules/windows/builtin/security/win_security_alert_enable_weak_encryption.yml

EventID=4738 (NewUacValue IN ("*8***", "*9***", "*A***", "*B***", "*C***", "*D***", "*E***", "*F***") NOT (OldUacValue IN ("*8***", "*9***", "*A***", "*B***", "*C***", "*D***", "*E***", "*F***"))) OR (NewUacValue IN ("*1****", "*3****", "*5****", "*7****", "*9****", "*B****", "*D****", "*F****") NOT (OldUacValue IN ("*1****", "*3****", "*5****", "*7****", "*9****", "*B****", "*D****", "*F****"))) OR (NewUacValue IN ("*8**", "*9**", "*A**", "*B**", "*C**", "*D**", "*E**", "*F**") NOT (OldUacValue IN ("*8**", "*9**", "*A**", "*B**", "*C**", "*D**", "*E**", "*F**")))